# Hugging Face API Token
# Required for accessing Hugging Face models
# Get your token from: https://huggingface.co/settings/tokens
HF_TOKEN=your_huggingface_token_here

# NVIDIA NIM API Key
# Optional but recommended for better performance in text-to-BibTeX conversion
# The system will use local Llama model as fallback if not provided
# Get your key from: https://build.nvidia.com/
NVIDIA_TOKEN=your_nvidia_api_key_here

# Secret key for JWT token generation
# Generate a random string (e.g., using: openssl rand -hex 32)
SECRET_KEY=your_secret_key_here_use_openssl_rand_hex_32

# Admin credentials for initial setup
# Change these after first login
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change_this_secure_password
